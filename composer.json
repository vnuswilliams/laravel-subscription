{
    "name": "vnuswilliams/laravel-subscription",
    "description": "A robust, fluent and payment-agnostic subscription management package for Laravel. Handles plans, lifecycle (trial, grace period, cancellation) and consumable feature quotas.",
    "keywords": [
        "laravel",
        "subscription",
        "plans",
        "billing",
        "saas",
        "quota",
        "features"
    ],
    "homepage": "https://github.com/vnuswilliams/laravel-subscription",
    "license": "MIT",
    "authors": [
        {
            "name": "Vnus Williams",
            "email": "payongvenus@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Vnuswilliams\\Subscription\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vnuswilliams\\Subscription\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vnuswilliams\\Subscription\\SubscriptionServiceProvider"
            ],
            "aliases": {
                "Subscription": "Vnuswilliams\\Subscription\\Facades\\Subscription"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse src --level=8",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
